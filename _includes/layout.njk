<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - WhatsApp网页版</title>
    <style>
        /* 页面基础样式 */
        body { font-family: -apple-system, system-ui, sans-serif; line-height: 1.8; color: #333; margin: 0; background: #f0f2f5; }
        .post-container { max-width: 900px; margin: 40px auto; background: #fff; padding: 40px; border-radius: 12px; box-shadow: 0 5px 20px rgba(0,0,0,0.05); }
        h1 { color: #075E54; border-bottom: 2px solid #eee; padding-bottom: 20px; }
        .post-content { font-size: 1.1rem; margin-bottom: 40px; }

        /* 互链组件样式 */
        .post-pagination {
            display: flex;
            justify-content: space-between;
            gap: 20px;
            padding-top: 30px;
            border-top: 1px solid #eee;
            margin-top: 50px;
        }
        .pagination-item {
            flex: 1;
            padding: 15px;
            border-radius: 8px;
            background: #f8f9fa;
            text-decoration: none;
            color: #128C7E;
            transition: all 0.3s;
            border: 1px solid transparent;
        }
        .pagination-item:hover {
            background: #fff;
            border-color: #128C7E;
            box-shadow: 0 4px 12px rgba(18,140,126,0.1);
        }
        .pagination-label {
            display: block;
            font-size: 0.8rem;
            color: #999;
            margin-bottom: 5px;
            text-transform: uppercase;
        }
        .pagination-title {
            display: block;
            font-weight: bold;
            font-size: 1rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .prev { text-align: left; }
        .next { text-align: right; }
        
        @media (max-width: 600px) {
            .post-pagination { flex-direction: column; }
        }
    </style>
</head>
<body>

    <article class="post-container">
    <main class="card">
    <h1>{{ title }}</h1>
    <div class="article-meta">发布日期：{{ date | dateFilter }}</div>
    <div class="article-body">
        {{ content | safe }}
    </div>
    <div class="nav-links">
        {% if prevPost %}<a href="{{ prevPost.url }}">上一篇：{{ prevPost.data.title }}</a>{% endif %}
        {% if nextPost %}<a href="{{ nextPost.url }}">下一篇：{{ nextPost.data.title }}</a>{% endif %}
    </div>
</main>
        
        <div style="text-align: center; margin-top: 40px;">
            <a href="/" style="color: #666; text-decoration: none;">返回首页</a>
        </div>
    </article>

</body>
</html>